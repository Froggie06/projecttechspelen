<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mijn Matches</title>
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/matching.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <%
        const fallbackProvinces = [...new Set(
            matches
                .map((match) => match.province)
                .filter(Boolean)
        )].sort((a, b) => a.localeCompare(b, "nl"))

        const fallbackPlayStyles = [...new Set(
            matches
                .map((match) => match.playStyle)
                .filter(Boolean)
        )]
            .map((playStyle) => ({
                value: playStyle,
                label: playStyle === "competitive" ? "Competitief" : playStyle === "casual" ? "Casual" : playStyle
            }))
            .sort((a, b) => a.label.localeCompare(b.label, "nl"))

        const safeFilters = typeof filters !== "undefined"
            ? {
                games: filters.games || [],
                provinces: filters.provinces?.length ? filters.provinces : fallbackProvinces,
                playStyles: filters.playStyles?.length ? filters.playStyles : fallbackPlayStyles
            }
            : {
                games: [],
                provinces: fallbackProvinces,
                playStyles: fallbackPlayStyles
            }
    %>

    <h1>Matches voor <%= currentUser.username %></h1>

    <section class="match-panel">
        <h2>Jouw profiel</h2>
        <p>Speelstijl: <%= currentUser.playStyle === "competitive" ? "Competitief" : currentUser.playStyle === "casual" ? "Casual" : "Nog niet ingevuld" %></p>
        <p>Provincie: <%= currentUser.province || "Niet ingevuld" %></p>
        <p>Provincie meetellen: <%= currentUser.includeProvinceInMatching ? "Ja" : "Nee" %></p>
        <p>Games: <%= currentUser.gameDetails.length ? currentUser.gameDetails.map((game) => game.name).join(", ") : "Nog geen games toegevoegd" %></p>
    </section>

    <section class="match-panel">
        <h2>Beste matches</h2>

        <% if (matches.length === 0) { %>
            <p>Nog geen matches gevonden. Voeg games toe of vul speelstijl en provincie aan.</p>
        <% } else { %>
            <section class="match-filters">
                <h3>Filters</h3>
                <p class="filter-intro">Filter op provincies en speelstijl. De carrousel toont daarna alleen de profielen die overblijven.</p>

                <div class="filter-grid">
                    <label class="filter-field" for="provinceFilter">
                        <span>Provincie</span>
                        <select id="provinceFilter" name="provinceFilter">
                            <option value="">Alle provincies</option>
                            <% safeFilters.provinces.forEach((province) => { %>
                                <option value="<%= province %>"><%= province %></option>
                            <% }) %>
                        </select>
                    </label>

                    <label class="filter-field" for="styleFilter">
                        <span>Speelstijl</span>
                        <select id="styleFilter" name="styleFilter">
                            <option value="">Alle speelstijlen</option>
                            <% safeFilters.playStyles.forEach((playStyle) => { %>
                                <option value="<%= playStyle.value %>"><%= playStyle.label %></option>
                            <% }) %>
                        </select>
                    </label>

                    <button class="filter-reset" id="resetFilters" type="button">Filters wissen</button>
                </div>
            </section>

            <section class="match-carousel" aria-label="Gefilterde matches">
                <p class="carousel-status" id="carouselStatus">Match 1 van <%= matches.length %></p>
                <p class="match-empty-message" id="noMatchesMessage" hidden>Er zijn geen matches die aan deze filters voldoen.</p>

                <div class="match-list" id="matchCarousel">
                <% matches.forEach((match, index) => { %>
                    <article
                        class="match-card"
                        data-match-card
                        data-index="<%= index %>"
                        data-play-style="<%= match.playStyle || '' %>"
                        data-province="<%= match.province || '' %>">
                        <div class="match-top">
                            <div>
                                <p class="match-rank">Match <%= index + 1 %></p>
                                <h3><%= match.username %></h3>
                                <p>
                                    <%= match.playStyle === "competitive" ? "Competitief" : match.playStyle === "casual" ? "Casual" : "Onbekend" %>
                                    <% if (match.province) { %>
                                        • <%= match.province %>
                                    <% } %>
                                </p>
                            </div>
                            <div class="score-badge"><%= match.score %>%</div>
                        </div>

                        <p><%= match.bio || "Deze gebruiker heeft nog geen bio ingevuld." %></p>
                        <p><strong>Gedeelde games:</strong> <%= match.sharedGames.length ? match.sharedGames.map((game) => game.name).join(", ") : "Geen" %></p>
                        <p><strong>Waarom deze match:</strong> <%= match.reasons.join(", ") %></p>

                        <a class="match-profile-link" href="/user/<%= encodeURIComponent(match.username) %>">Bekijk profiel</a>

                        <% if (match.isFriend) { %>
                            <button disabled>Vrienden</button>

                        <% } else if (match.requestSent) { %>
                            <button disabled>Verzoek verzonden</button>

                        <% } else { %>
                            <button 
                                class="connect-btn" 
                                data-user-id="<%= match._id %>">
                                Connect
                            </button>
                        <% } %>

                    </article>
                <% }) %>
                </div>

                <div class="carousel-controls">
                    <button id="prevMatch" type="button" aria-label="Vorige match">Vorige</button>
                    <button id="nextMatch" type="button" aria-label="Volgende match">Volgende</button>
                </div>
            </section>
        <% } %>
    </section>

    <a href="/account">Terug naar account</a>
    <script src="/js/matching.js"></script>
</body>
</html>
