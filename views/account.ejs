<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <link rel="stylesheet" href="/css/login.css">
</head>
<body>
    <h1><%= user.username %></h1>

    <img src="<%= user.profilePicture || 'images/defaultAvatar.jpg' %>" width="150">

    <p>Bio: <%= user.bio %></p>
    <p>Speelstijl: <%= user.playStyle === "competitive" ? "Competitief" : user.playStyle === "casual" ? "Casual" : "Nog niet ingevuld" %></p>
    <p>Provincie: <%= user.province || "Niet ingevuld" %></p>
    <p>Provincie meetellen: <%= user.includeProvinceInMatching ? "Ja" : "Nee" %></p>

    <a href="/logout">Logout</a>
    <a href="/matching">Bekijk mijn matches</a>

    <h2>Profiel aanpassen</h2>

    <form action="/update-profile" method="post" enctype="multipart/form-data">
        <textarea name="bio" placeholder="Bio"><%= user.bio || "" %></textarea>

        <select name="playStyle">
            <option value="">Kies speelstijl</option>
            <option value="competitive" <%= user.playStyle === 'competitive' ? 'selected' : '' %>>Competitief</option>
            <option value="casual" <%= user.playStyle === 'casual' ? 'selected' : '' %>>Casual</option>
        </select>

        <select name="province">
            <option value="">Kies provincie</option>
            <% provinces.forEach((province) => { %>
                <option value="<%= province %>" <%= user.province === province ? 'selected' : '' %>><%= province %></option>
            <% }) %>
        </select>

        <label class="checkbox-row">
            <input type="checkbox" name="includeProvinceInMatching" <%= user.includeProvinceInMatching ? 'checked' : '' %>>
            <span>Neem provincie mee in matching</span>
        </label>

        <label>Profielfoto:</label>
        <input type="file" name="profilePicture">

        <button type="submit">Opslaan</button>
    </form>

    <h2>Zoek een game</h2>

    <div class="search-container">
        <input type="search" id="searchInput" placeholder="Voeg games toe..." autocomplete="off"/>
        <div id="dropdown"></div>
    </div>

    <h2>Mijn games</h2>
    <% if (games.length === 0) { %>
        <p>Je hebt nog geen games toegevoegd.</p>
    <% } else { %>
        <div class="game-list">
            <% games.forEach((game) => { %>
                <article class="game-card">
                    <% if (game.cover) { %>
                        <img src="<%= game.cover %>" width="60" alt="<%= game.name %>">
                    <% } %>
                    <p><%= game.name %></p>
                </article>
            <% }) %>
        </div>
    <% } %>

    <button id="showSecurity">Verander wachtwoord of gebruikersnaam</button>

    <form id="securityForm" action="/update-profile" method="post" style="display:none;">
        <input type="text" name="username" placeholder="Nieuwe username">
        <input type="password" name="newPassword" placeholder="Nieuw wachtwoord">

        <button type="submit">Opslaan</button>
    </form>

    <a href="/user/<%= user.username %>">Bekijk mijn profiel</a>

    <script src="/js/login.js"></script>
</body>
</html>
